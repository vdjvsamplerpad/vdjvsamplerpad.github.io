# Local dev default: use the Supabase CLI stack, usually http://127.0.0.1:54321
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_local_anon_key_here
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Safety switch: keep false/empty for normal development.
# Set true only when you intentionally want local dev to hit a hosted Supabase project.
VITE_ALLOW_REMOTE_SUPABASE_IN_DEV=false

# Optional when testing against a hosted project or non-default local functions base
# VITE_EDGE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

VITE_ADMIN_EXPORT_TOKEN_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nYOUR_ES256_P256_PUBLIC_KEY\n-----END PUBLIC KEY-----
VITE_ENTITLEMENT_TOKEN_PUBLIC_KEY_PEM=-----BEGIN PUBLIC KEY-----\nYOUR_ES256_P256_PUBLIC_KEY\n-----END PUBLIC KEY-----

# Optional legacy compatibility switch (recommended: false)
ENABLE_LEGACY_EXPRESS_API=false

# Android release signing and versioning
# ANDROID_RELEASE_KEYSTORE_PATH=path/to/release-keystore.jks
# ANDROID_RELEASE_KEY_ALIAS=your_key_alias
# ANDROID_RELEASE_KEYSTORE_PASSWORD=your_keystore_password
# ANDROID_RELEASE_KEY_PASSWORD=your_key_password
# ANDROID_RELEASE_VERSION_NAME=0.1.0
# ANDROID_RELEASE_VERSION_CODE=100

# Electron auto-update feed
# ELECTRON_AUTO_UPDATE_URL=https://updates.example.com/vdjv/win
# ELECTRON_AUTO_UPDATE_CHANNEL=latest
